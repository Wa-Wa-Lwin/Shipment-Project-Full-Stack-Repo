# ============================

# Laravel Backend Environment

# Safe Template (.env.example)

# ============================

APP_NAME=XEN_ERP_BACKEND
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================

# Main Database

# ============================

DB_CONNECTION=sqlsrv
DB_HOST=127.0.0.1
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE_LOGISTICS=

# ============================

# MFG Database

# ============================

DB_HOST_MFG=127.0.0.1
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE_MFG=

# ============================

# XEN DB

# ============================

DB_HOST_XEN_DB=127.0.0.1
DB_PORT_XEN_DB=1433
DB_DATABASE_XEN_DB=
DB_USERNAME_XEN_DB=
DB_PASSWORD_XEN_DB=

# ============================

# XEN API Database

# ============================

DB_HOST_XEN_API=127.0.0.1
DB_PORT_XEN_API=1433
DB_DATABASE_XEN_API_MFG=
DB_USERNAME_XEN_API=
DB_PASSWORD_XEN_API=

# ============================

# Session

# ============================

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================

# Queue / Cache

# ============================

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

# ============================

# Redis

# ============================

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# ============================

# Mail

# ============================

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=[hello@example.com](mailto:hello@example.com)
MAIL_FROM_NAME="${APP_NAME}"

# ============================

# AWS

# ============================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================

# Frontend Build

# ============================

VITE_APP_NAME="${APP_NAME}"

# ============================

# Azure SSO

# ============================

AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
ALLOWED_DOMAIN=

# ============================

# FedEx API

# ============================

FEDEX_API_URL=https://apis.fedex.com
FEDEX_TOKEN_URL=https://apis.fedex.com/oauth/token
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=

# ============================

# Notification Emails

# ============================

WAREHOUSE_EMAILS=
LOGISTIC_TEAM_EMAILS=

# ============================

# SAP Enterpryze

# ============================

SAP_URL=https://192.168.68.16:50000/b1s/v1
SAP_USERNAME=
SAP_PASSWORD=
SAP_COMPANY_DB=
